{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Mancala Gaming Studio Editor",
  "version": "0.1.0",
  "identifier": "com.mancala-gaming.studio-editor",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Mancala Gaming Studio Editor",
        "width": 1440,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["mancala"],
        "name": "Mancala Gaming Studio Project",
        "description": "Mancala Gaming Studio Editor project file",
        "mimeType": "application/x-mancala-project",
        "role": "Editor"
      }
    ]
  }
}
